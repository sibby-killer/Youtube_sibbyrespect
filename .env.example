# Groq API Key (For AI Script Generation)
GROQ_API_KEY=your_groq_key

# Pexels API Key (For HD Background B-Roll)
PEXELS_API_KEY=your_pexels_key

# Database / Admin Panel (Supabase)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Reddit API (For Auto-Topic Generation)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret

# Flask Dashboard Secret (Used for sessions)
FLASK_SECRET_KEY=any_random_secure_string_here
